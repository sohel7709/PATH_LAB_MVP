# Copy this file to `.env` on the EC2 server (never commit the real .env)
NODE_ENV=production
PORT=5001

# MongoDB Atlas connection string (already in use — reuse or create a prod cluster/DB)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Generate a long random value, e.g.: openssl rand -base64 48
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRE=30d
